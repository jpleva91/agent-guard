{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/claude-hook-wrapper.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node apps/cli/dist/bin.js claude-hook post --store sqlite"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'M=$(git rev-parse --path-format=absolute --git-common-dir); M=${M%/.git}; [ -f \"$M/.env\" ] && [ ! -f .env ] && cp \"$M/.env\" .env || true'",
            "timeout": 5000,
            "blocking": true
          },
          {
            "type": "command",
            "command": "test -f node_modules/.modules.yaml || pnpm install --force",
            "timeout": 120000,
            "blocking": true
          },
          {
            "type": "command",
            "command": "test -f apps/cli/dist/bin.js || pnpm build; test -f apps/cli/dist/bin.js",
            "timeout": 120000,
            "blocking": true
          },
          {
            "type": "command",
            "command": "bash scripts/session-persona-check.sh",
            "timeout": 5000,
            "blocking": true
          },
          {
            "type": "command",
            "command": "node apps/cli/dist/bin.js status",
            "timeout": 10000,
            "blocking": false
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node apps/cli/dist/bin.js claude-hook notify --store sqlite",
            "timeout": 15000,
            "blocking": false
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node apps/cli/dist/bin.js claude-hook stop --store sqlite",
            "timeout": 15000,
            "blocking": false
          }
        ]
      }
    ]
  }
}
