{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node apps/cli/dist/bin.js claude-hook pre --store sqlite"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node apps/cli/dist/bin.js claude-hook post --store sqlite"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -f apps/cli/dist/bin.js || pnpm build",
            "timeout": 120000,
            "blocking": true
          },
          {
            "type": "command",
            "command": "node apps/cli/dist/bin.js status",
            "timeout": 10000,
            "blocking": false
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node apps/cli/dist/bin.js claude-hook stop --store sqlite",
            "timeout": 15000,
            "blocking": false
          }
        ]
      }
    ]
  }
}