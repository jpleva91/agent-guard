{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "bash": "node apps/cli/dist/bin.js copilot-hook pre",
        "timeoutSec": 30
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "node apps/cli/dist/bin.js copilot-hook post",
        "timeoutSec": 10
      }
    ]
  }
}