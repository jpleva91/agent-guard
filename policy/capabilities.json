{
  "version": "1.0.0",
  "description": "Agent capability policy for AgentGuard repository operations",
  "allowed_actions": [
    "file.read",
    "file.write",
    "file.create",
    "test.run",
    "lint.run",
    "git.diff",
    "git.status",
    "git.commit",
    "git.branch",
    "build.run"
  ],
  "restricted_actions": [
    "shell.exec.arbitrary",
    "network.call.external",
    "git.push.force",
    "git.rebase.interactive",
    "git.reset.hard",
    "file.delete.bulk",
    "dependency.add",
    "dependency.remove",
    "ci.modify"
  ],
  "file_policies": {
    "read_any": true,
    "write_allowed_paths": [
      "src/**",
      "tests/**",
      "scripts/**",
      "spec/**",
      "policy/**"
    ],
    "write_denied_paths": [
      ".github/workflows/**",
      ".env",
      "*.secret",
      "credentials.*"
    ]
  },
  "test_policy": {
    "must_pass_before_commit": true,
    "command": "npm test"
  },
  "lint_policy": {
    "must_pass_before_commit": true,
    "commands": ["npm run lint", "npm run format"]
  }
}
