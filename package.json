{
  "name": "bugmon",
  "version": "2.0.0",
  "description": "A Pokémon-style browser RPG themed around software bugs",
  "type": "module",
  "bin": {
    "bugmon": "./core/cli/bin.js"
  },
  "files": [
    "core/",
    "ecosystem/"
  ],
  "scripts": {
    "test": "node tests/run.js",
    "simulate": "node simulate.js",
    "simulate:quick": "node simulation/cli.js --battles 1000",
    "simulate:full": "node simulation/cli.js --battles 50000",
    "simulate:compare": "node simulation/cli.js --compare",
    "sync-data": "node scripts/sync-data.js",
    "build": "node scripts/build.js",
    "build:tiny": "node scripts/build.js --no-sprites",
    "budget": "node scripts/build.js --no-sprites",
    "serve": "python3 -m http.server",
    "dev": "node core/cli/bin.js"
  },
  "keywords": [
    "game",
    "rpg",
    "pokemon",
    "simulation",
    "debugging",
    "developer-tools",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.27.3",
    "terser": "^5.46.0"
  }
}
