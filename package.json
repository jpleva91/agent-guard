{
  "name": "bugmon",
  "version": "1.0.0",
  "description": "A Pokémon-style browser RPG themed around software bugs",
  "type": "module",
  "bin": {
    "bugmon": "./core/cli/bin.js"
  },
  "files": [
    "core/",
    "domain/",
    "ecosystem/",
    "agentguard/",
    "hooks/",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jpleva91/BugMon.git"
  },
  "homepage": "https://github.com/jpleva91/BugMon#readme",
  "bugs": {
    "url": "https://github.com/jpleva91/BugMon/issues"
  },
  "author": "jpleva91",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node tests/run.js",
    "test:coverage": "c8 --check-coverage --lines 50 node tests/run.js",
    "lint": "eslint game/ core/ domain/ agentguard/ ecosystem/ simulation/ tests/",
    "lint:fix": "eslint --fix game/ core/ domain/ agentguard/ ecosystem/ simulation/ tests/",
    "format": "prettier --check game/ core/ domain/ agentguard/ ecosystem/ simulation/",
    "format:fix": "prettier --write game/ core/ domain/ agentguard/ ecosystem/ simulation/",
    "simulate": "node simulate.js",
    "simulate:quick": "node simulation/cli.js --battles 1000",
    "simulate:full": "node simulation/cli.js --battles 50000",
    "simulate:compare": "node simulation/cli.js --compare",
    "contracts:check": "node scripts/check-contracts.js",
    "sync-data": "node scripts/sync-data.js",
    "build": "node scripts/build.js",
    "build:tiny": "node scripts/build.js --no-sprites",
    "build:debug": "node scripts/build.js --sourcemap",
    "budget": "node scripts/build.js --no-sprites",
    "serve": "node scripts/dev-server.js",
    "dev": "node core/cli/bin.js",
    "build:ts": "tsc --noEmit && tsx esbuild.config.ts",
    "ts:check": "tsc --noEmit",
    "ts:test": "vitest run",
    "ts:test:watch": "vitest"
  },
  "keywords": [
    "game",
    "rpg",
    "pokemon",
    "simulation",
    "debugging",
    "developer-tools",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.5",
    "c8": "^11.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "terser": "^5.46.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "pino": "^10.3.1"
  }
}
