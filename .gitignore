dist/
node_modules/

# Database files — never commit
*.db
*.sqlite
*.sqlite3
runtime/events/*
runtime/replay/*
!runtime/events/.gitkeep
!runtime/replay/.gitkeep
# Governance runtime — ignore per-run artifacts, track audit trail
.agentguard/*
!.agentguard/events/.gitkeep
!.agentguard/decisions/.gitkeep
logs/*
!logs/.gitkeep
