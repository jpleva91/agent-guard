dist/
node_modules/
coverage/
.turbo/
*.tsbuildinfo

# Database files — never commit (use remote storage for sharing)
*.db
*.sqlite
*.sqlite3
runtime/events/*
runtime/replay/*
!runtime/events/.gitkeep
!runtime/replay/.gitkeep
# Governance runtime — ignore all local artifacts
.agentguard/*
!.agentguard/events/.gitkeep
!.agentguard/decisions/.gitkeep
!.agentguard/squad-manifest.yaml
!.agentguard/squads/
**/.agentguard/*
!**/.agentguard/events/.gitkeep
!**/.agentguard/decisions/.gitkeep
!**/.agentguard/squad-manifest.yaml
!**/.agentguard/squads/
logs/*
!logs/.gitkeep
**/logs/runtime-events.jsonl
# Hook-generated event counters (redundant with governance DB)
.events.json
# Benchmark output (uploaded as CI artifact, not tracked in git)
**/bench-results.json
.claude/worktrees/

# Agent identity and session state (session-scoped, never committed)
.agentguard-identity
.agentguard-root-session

# Environment
.env
.env.local
.env.*.local
crates/kernel-core/target/
