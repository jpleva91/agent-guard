{
  "name": "@red-codes/agentguard-mcp",
  "version": "2.9.3",
  "description": "AgentGuard MCP server \u2014 governance tools for AI coding agents",
  "type": "module",
  "license": "Apache-2.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentguard-mcp": "./dist/server.js"
  },
  "exports": {
    ".": {
