{
  "name": "@red-codes/telemetry-server",
  "version": "0.1.0",
  "description": "Telemetry API server for AgentGuard — deployable to Vercel, AWS Lambda, or standalone Node.js",
  "type": "module",
  "license": "Apache-2.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "eslint src/",
    "ts:check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@red-codes/core": "workspace:*",
    "@red-codes/telemetry": "workspace:*",
    "@red-codes/telemetry-client": "workspace:*",
    "@vercel/postgres": "^0.10.0",
    "hono": "^4.7.0"
  }
}
