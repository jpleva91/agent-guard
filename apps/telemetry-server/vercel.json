{
  "buildCommand": "cd ../.. && pnpm install --frozen-lockfile && pnpm build --filter=@red-codes/telemetry-server...",
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "dist/entry-vercel.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "dist/entry-vercel.js"
    }
  ]
}
