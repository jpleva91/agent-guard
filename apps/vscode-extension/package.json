{
  "name": "agentguard-vscode",
  "displayName": "AgentGuard",
  "description": "Governance run status and event visibility for AgentGuard",
  "version": "2.9.2",
  "publisher": "agentguard",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.agentguard",
    "workspaceContains:agentguard.yaml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentguard",
          "title": "AgentGuard",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "agentguard": [
        {
          "id": "agentguard.runStatus",
          "name": "Run Status"
        },
        {
          "id": "agentguard.recentEvents",
          "name": "Recent Events"
        },
        {
          "id": "agentguard.runHistory",
          "name": "Run History"
        }
      ]
    },
    "commands": [
      {
        "command": "agentguard.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "AgentGuard"
      },
      {
        "command": "agentguard.clearDiagnostics",
        "title": "Clear Violation Indicators",
        "category": "AgentGuard"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "agentguard.refresh",
          "when": "view == agentguard.runStatus || view == agentguard.recentEvents || view == agentguard.runHistory",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "AgentGuard",
      "properties": {
        "agentguard.notifications.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable governance notifications for policy violations and invariant violations."
        },
        "agentguard.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline violation indicators in the editor. Shows invariant violations and policy denials in the Problems panel and as inline decorations."
        },
        "agentguard.notifications.severityOverrides": {
          "type": "object",
          "default": {},
          "description": "Override the default notification severity for specific event kinds. Keys: PolicyDenied, InvariantViolation, BlastRadiusExceeded, ActionEscalated. Values: information, warning, error.",
          "properties": {
            "PolicyDenied": {
              "type": "string",
              "enum": [
                "information",
                "warning",
                "error"
              ],
              "description": "Severity for policy denial notifications (default: warning)"
            },
            "InvariantViolation": {
              "type": "string",
              "enum": [
                "information",
                "warning",
                "error"
              ],
              "description": "Severity for invariant violation notifications (default: error)"
            },
            "BlastRadiusExceeded": {
              "type": "string",
              "enum": [
                "information",
                "warning",
                "error"
              ],
              "description": "Severity for blast radius exceeded notifications (default: error)"
            },
            "ActionEscalated": {
              "type": "string",
              "enum": [
                "information",
                "warning",
                "error"
              ],
              "description": "Severity for action escalation notifications (default: information)"
            }
          },
          "additionalProperties": false
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.9.3"
  }
}
