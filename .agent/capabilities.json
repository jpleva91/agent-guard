{
  "description": "Defines what actions autonomous agents may perform inside this repository.",
  "allowed": [
    "file.read:**/*",
    "file.write:src/**",
    "file.write:tests/**",
    "file.write:scripts/**",
    "file.write:.agent/**",
    "file.write:policy/**",
    "file.write:spec/**",
    "test.run:npm test",
    "test.run:npm run ts:test",
    "test.run:npm run test:coverage",
    "lint.run:npm run lint",
    "lint.fix:npm run lint:fix",
    "format.check:npm run format",
    "format.fix:npm run format:fix",
    "build.run:npm run build:ts",
    "ts.check:npm run ts:check",
    "git.diff",
    "git.status",
    "git.log",
    "git.add",
    "git.commit",
    "git.branch"
  ],
  "restricted": [
    "shell.exec:arbitrary",
    "network.call:external",
    "git.push:main",
    "git.push:--force",
    "git.rebase:main",
    "npm.install:production-dependency"
  ],
  "notes": {
    "npm.install": "Only dev dependencies allowed unless explicitly approved.",
    "git.push:main": "Requires human review. Push to feature branches only."
  }
}
