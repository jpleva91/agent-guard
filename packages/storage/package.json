{
  "name": "@red-codes/storage",
  "version": "0.1.0",
  "description": "Storage backends for AgentGuard (SQLite, Firestore, JSONL)",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "lint": "eslint src/",
    "ts:check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@red-codes/core": "workspace:*",
    "@red-codes/events": "workspace:*",
    "@red-codes/kernel": "workspace:*",
    "@red-codes/analytics": "workspace:*",
    "@red-codes/telemetry": "workspace:*"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0"
  }
}
